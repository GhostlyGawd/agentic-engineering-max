{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/claude-context-inject.ps1"
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/state-writer-sweep.ps1"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/state-writer.ps1"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/state-drift-check.ps1"
          }
        ]
      }
    ]
  }
}
