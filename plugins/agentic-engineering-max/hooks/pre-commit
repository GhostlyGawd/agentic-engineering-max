#!/usr/bin/env bash
# hooks/pre-commit - bash shim invoked by git pre-commit.
#
# Git looks for hook files named exactly 'pre-commit' (no extension).
# The real logic lives in hooks/pre-commit.ps1 to match the rest of
# the Dev_006 toolchain (bin/*.ps1).
set -e
hook_ps1="$(dirname "$0")/pre-commit.ps1"
# pwsh (PS 7+) is required; clear-fail if absent. v2 Option A dropped the
# PS 5.1 dependency, so the shim invokes pwsh on every platform
# (Linux/macOS/CI/Windows) and hard-fails with a diagnostic when pwsh is
# not on PATH.
if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$hook_ps1"
else
  echo "pre-commit: pwsh (PowerShell 7+) not found on PATH" >&2
  exit 1
fi
